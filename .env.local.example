# Environment Variables
# Copy this to .env.local and fill in your values

# Vercel KV (required for production on Vercel)
# Get these from your Vercel dashboard → Storage → KV
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Admin password for the recipe management page
ADMIN_PASSWORD=mealprep2024

# Your deployed app URL (for QR code generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000
